{
  "name": "fishon-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "FishOn monorepo: deterministic core (published MCP server/library) + public web planner app.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @volare-consulting/fishon",
    "build:web": "npm run build -w @fishon/web",
    "test": "npm run test --workspaces --if-present",
    "mcp": "npm run mcp -w @volare-consulting/fishon",
    "forecast": "npm run forecast -w @volare-consulting/fishon",
    "dev:web": "npm run dev -w @fishon/web"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/volare-consulting-software/fishweather.git"
  },
  "license": "MIT"
}
